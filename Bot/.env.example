# Required
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional (bot owner bypass for owner-only commands)
BOT_OWNER_ID=
DISCORD_OWNER_ID=

# Slash command sync behavior
REGISTER_SLASH_ON_READY=0
REGISTER_SLASH_FORCE=0

# Health endpoint
HEALTH_ENABLED=1
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8080

# Automatic DB backups
AUTO_BACKUP_ON_READY=1
AUTO_BACKUP_INTERVAL_MIN=360
AUTO_BACKUP_KEEP=24

# Optional Spotify support (playlist/album resolve)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=TR

# Optional visuals
SERVERTOP_THUMBNAIL_URL=
KICK_LOG_THUMBNAIL_URL=
BAN_LOG_THUMBNAIL_URL=
UNBAN_LOG_THUMBNAIL_URL=

# Optional tunables
WORD_GAME_APPROVE_EMOJI=
SUPPRESSED_ERROR_WARN=0
SUPPRESSED_ERROR_CACHE_TTL_MS=2000
PROTECTION_CFG_CACHE_TTL_MS=5000
WELCOME_HUMAN_COUNT_CACHE_TTL_MS=300000
LOG_BAN_TOTAL_SYNC_INTERVAL_MS=600000
LOG_CFG_CACHE_TTL_MS=5000
LOG_SETUP_CHANNEL_CONCURRENCY=12
LOG_SETUP_FORUM_CONCURRENCY=6
LOG_SETUP_TOPIC_CONCURRENCY=8
